# LifeLine Blood Network - Environment Configuration
# Copy this file to .env and fill in your actual values

# Database Configuration
DB_HOST=localhost
DB_NAME=blood_donor_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Application Settings
APP_NAME=LifeLine Blood Network
APP_URL=http://localhost:8080
APP_ENV=development
APP_DEBUG=true
APP_PATH=

# Security
SESSION_LIFETIME=1440
CSRF_TOKEN_LIFETIME=3600
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Email Configuration (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_ADDRESS=noreply@lifelineblood.network
MAIL_FROM_NAME="LifeLine Blood Network"
MAIL_ENCRYPTION=tls

# Optional: Google Maps API for distance-based search
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Admin Settings
ADMIN_EMAIL=admin@bloodsystem.com
